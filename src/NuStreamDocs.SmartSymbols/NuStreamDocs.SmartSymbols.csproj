<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.SmartSymbols</PackageId>
    <Description>Auto-substitute typographic symbols in your NuStreamDocs markdown — copyright, registered, trademark, plus-minus, arrows, and common fractions — without needing to type the Unicode characters yourself.</Description>
    <RootNamespace>NuStreamDocs.SmartSymbols</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Markdown.Common\NuStreamDocs.Markdown.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.SmartSymbols.Tests" />
  </ItemGroup>

</Project>
