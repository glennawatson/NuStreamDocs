<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.SmartSymbols</PackageId>
    <Description>Smart-symbols plugin for NuStreamDocs. Implements pymdownx.smartsymbols defaults — copyright/registered/trademark, c/o, +/-, =/=, arrow forms, and the common fractions — as a UTF-8 markdown preprocessor.</Description>
    <RootNamespace>NuStreamDocs.SmartSymbols</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Markdown.Common\NuStreamDocs.Markdown.Common.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Common\NuStreamDocs.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.SmartSymbols.Tests" />
  </ItemGroup>

</Project>
