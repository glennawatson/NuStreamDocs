<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Mermaid</PackageId>
    <Description>Mermaid diagram plugin for NuStreamDocs. Retags fenced mermaid code blocks into a container the mermaid runtime auto-discovers and pulls the runtime in via a head &lt;script&gt; tag.</Description>
    <RootNamespace>NuStreamDocs.Mermaid</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Common\NuStreamDocs.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Mermaid.Tests" />
  </ItemGroup>

</Project>
