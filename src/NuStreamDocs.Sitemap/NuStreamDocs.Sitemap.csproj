<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Sitemap</PackageId>
    <Description>Site-level emitters for NuStreamDocs — sitemap.xml + robots.txt, a default 404 page, and redirect stubs. Each plugin is opt-in via its own builder extension.</Description>
    <RootNamespace>NuStreamDocs.Sitemap</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Common\NuStreamDocs.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Sitemap.Tests" />
  </ItemGroup>

</Project>
