<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Metadata</PackageId>
    <Description>Apply shared frontmatter to your NuStreamDocs pages without copying it into every file. Drop a `_meta.yml` next to a folder and every page in it inherits those keys; override per page with a `page.meta.yml` sidecar.</Description>
    <RootNamespace>NuStreamDocs.Metadata</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Metadata.Tests" />
  </ItemGroup>

</Project>
