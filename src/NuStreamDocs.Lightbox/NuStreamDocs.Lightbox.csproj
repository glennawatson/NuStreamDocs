<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Lightbox</PackageId>
    <Description>glightbox-compatible image lightbox plugin for NuStreamDocs. Adds the glightbox CSS + JS to every page head and wraps content images in &lt;a&gt; lightbox triggers.</Description>
    <RootNamespace>NuStreamDocs.Lightbox</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Common\NuStreamDocs.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Lightbox.Tests" />
  </ItemGroup>

</Project>
