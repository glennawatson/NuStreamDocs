<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Privacy</PackageId>
    <Description>Stop your NuStreamDocs pages from leaking visitor data to third-party CDNs. Downloads external images, scripts, and stylesheets at build time, ships them with your site, and rewrites the page HTML to load the local copies.</Description>
    <RootNamespace>NuStreamDocs.Privacy</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Polly" />
    <PackageReference Include="Polly.RateLimiting" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Privacy.Tests" />
    <InternalsVisibleTo Include="NuStreamDocs.Benchmarks" />
  </ItemGroup>

</Project>
