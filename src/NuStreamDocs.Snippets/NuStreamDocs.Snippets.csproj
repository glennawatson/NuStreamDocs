<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Snippets</PackageId>
    <Description>Reuse content across pages in your NuStreamDocs documentation. Write `--8&lt;-- "shared/note.md"` and the contents of that file are spliced inline at build time.</Description>
    <RootNamespace>NuStreamDocs.Snippets</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Markdown.Common\NuStreamDocs.Markdown.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Snippets.Tests" />
  </ItemGroup>

</Project>
