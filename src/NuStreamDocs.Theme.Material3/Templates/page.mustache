<!doctype html>
<html lang="{{language}}" class="md3">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{page_title}}{{#site_name}} - {{site_name}}{{/site_name}}</title>
    {{> head_styles}}
  </head>
  <body data-md-color-scheme="default">
    <div class="md-container">
      {{> header}}
      <main class="md-main">
        <div class="md-main__inner md-grid">
          {{> sidebar}}
          <div class="md-content">
            <article class="md-content__inner md-typeset">
              {{{body}}}
            </article>
          </div>
        </div>
      </main>
      {{> footer}}
    </div>
    {{#scroll_to_top}}
    <a href="#" class="md-top" data-md-component="top" aria-label="Back to top" hidden>&#8593;</a>
    <style>.md-top{position:fixed;right:1rem;bottom:1rem;display:inline-flex;align-items:center;justify-content:center;width:2.4rem;height:2.4rem;border-radius:50%;background:var(--md3-primary,#6750a4);color:#fff;text-decoration:none;box-shadow:0 2px 6px rgba(0,0,0,.2);transition:opacity .15s ease}.md-top[hidden]{display:none}</style>
    <script>(function(){var b=document.querySelector('[data-md-component=top]');if(!b)return;b.addEventListener('click',function(e){e.preventDefault();window.scrollTo({top:0,behavior:'smooth'})});function u(){if(window.scrollY>200)b.removeAttribute('hidden');else b.setAttribute('hidden','')}u();window.addEventListener('scroll',u,{passive:true})})();</script>
    {{/scroll_to_top}}
    {{#toc_follow}}
    <script>(function(){var hs=document.querySelectorAll('.md-content article :is(h1,h2,h3,h4,h5,h6)[id]');var ls=document.querySelectorAll('.md-toc a[href^="#"]');if(!hs.length||!ls.length)return;function active(id){ls.forEach(function(a){a.classList.toggle('md-toc__link--active',a.getAttribute('href')==='#'+id)})}var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)active(e.target.id)})},{rootMargin:'-30% 0px -65% 0px'});hs.forEach(function(h){io.observe(h)})})();</script>
    {{/toc_follow}}
    {{> body_scripts}}
  </body>
</html>
