<footer class="md-footer">
    {{#prev_url}}{{^next_url}}
        <nav class="md-footer__inner md-grid" aria-label="Footer">
            <a class="md-footer__link md-footer__link--prev" href="{{prev_url}}" rel="prev"><span
                class="md-footer__direction">Previous</span><span class="md-footer__title">{{prev_title}}</span></a>
        </nav>
    {{/next_url}}{{/prev_url}}
    {{#next_url}}
        <nav class="md-footer__inner md-grid" aria-label="Footer">
            {{#prev_url}}<a class="md-footer__link md-footer__link--prev" href="{{prev_url}}" rel="prev"><span
                class="md-footer__direction">Previous</span><span
                class="md-footer__title">{{prev_title}}</span></a>{{/prev_url}}
            <a class="md-footer__link md-footer__link--next" href="{{next_url}}" rel="next"><span
                class="md-footer__direction">Next</span><span class="md-footer__title">{{next_title}}</span></a>
        </nav>
    {{/next_url}}
    <div class="md-footer-meta md-typeset">
        <div class="md-footer-meta__inner md-grid">
            {{#footer_partial}}{{{footer_partial}}}{{/footer_partial}}
            {{^footer_partial}}{{#copyright_html}}{{{copyright_html}}}{{/copyright_html}}{{^copyright_html}}
                <div class="md-copyright">{{copyright}}</div>{{/copyright_html}}{{#social_present}}
            <div class="md-social">{{/social_present}}{{#social}}
                <a href="{{social_url}}" target="_blank" rel="noopener" title="{{social_title}}"
                   class="md-social__link">{{{social_icon}}}</a>{{/social}}{{#social_present}}
            </div>{{/social_present}}{{/footer_partial}}
        </div>
    </div>
</footer>
