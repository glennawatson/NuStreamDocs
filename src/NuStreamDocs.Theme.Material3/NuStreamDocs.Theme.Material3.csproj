<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Theme.Material3</PackageId>
    <Description>Material Design 3 theme for NuStreamDocs. MD3 design tokens (color roles, shape, typography, elevation) for a modern look. Page template, styles, and scripts all ship inside the package — no external assets to manage.</Description>
    <RootNamespace>NuStreamDocs.Theme.Material3</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Theme.Common\NuStreamDocs.Theme.Common.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Templating\NuStreamDocs.Templating.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Templates\**\*" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Theme.Material3.Tests" />
  </ItemGroup>

</Project>
