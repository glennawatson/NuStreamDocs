<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Xrefs</PackageId>
    <Description>Cross-link references between separate NuStreamDocs sites by symbol name. Publishes an `xrefmap.json` catalog of every named anchor in your build, and consumes catalogs from other sites so cross-site references resolve to the right page.</Description>
    <RootNamespace>NuStreamDocs.Xrefs</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Autorefs\NuStreamDocs.Autorefs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Xrefs.Tests" />
  </ItemGroup>

</Project>
