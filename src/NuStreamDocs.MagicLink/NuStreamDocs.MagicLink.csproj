<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.MagicLink</PackageId>
    <Description>Auto-link bare URLs and email addresses in your NuStreamDocs markdown. Write `https://example.com` or `me@example.com` and it renders as a clickable link without needing explicit angle brackets or markdown link syntax.</Description>
    <RootNamespace>NuStreamDocs.MagicLink</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Markdown.Common\NuStreamDocs.Markdown.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.MagicLink.Tests" />
  </ItemGroup>

</Project>
