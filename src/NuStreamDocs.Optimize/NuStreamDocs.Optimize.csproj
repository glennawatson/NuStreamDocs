<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Optimize</PackageId>
    <Description>Pre-compress your built NuStreamDocs site with gzip and Brotli. Lets a static web server serve compressed responses without re-compressing on every request.</Description>
    <RootNamespace>NuStreamDocs.Optimize</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Optimize.Tests" />
  </ItemGroup>

</Project>
