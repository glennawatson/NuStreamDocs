<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Templating</PackageId>
    <Description>Mustache-style template engine used by NuStreamDocs themes to render page shells. AOT-friendly and allocation-conscious. Theme authors pull this in to render their templates.</Description>
    <RootNamespace>NuStreamDocs.Templating</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Templating.Tests" />
  </ItemGroup>

</Project>
