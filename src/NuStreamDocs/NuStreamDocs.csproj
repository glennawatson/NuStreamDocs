<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs</PackageId>
    <Description>AOT-friendly, allocation-conscious Markdown and static-site generator core. Custom span/UTF-8 parser, HTML emitter, page pipeline, plugin contract, content-hash incremental builds. Theme assets ship in dedicated theme plugin assemblies (e.g. NuStreamDocs.Theme.Material).</Description>
    <RootNamespace>NuStreamDocs</RootNamespace>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs.Common\NuStreamDocs.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core stays free of SourceDocParser. The CSharpApiGenerator plugin
         (NuStreamDocs.CSharpApiGenerator, separate assembly) takes the
         dependency and registers itself via builder.UseCSharpApiGenerator(). -->
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" />
    <PackageReference Include="System.IO.Hashing" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Tests" />
    <InternalsVisibleTo Include="NuStreamDocs.Benchmarks" />
  </ItemGroup>

</Project>
