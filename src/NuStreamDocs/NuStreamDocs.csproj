<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs</PackageId>
    <Description>Static-site generator core for building documentation sites from markdown. Includes the markdown parser, HTML renderer, page pipeline, plugin host, and incremental rebuild support. AOT-friendly and allocation-conscious. Pair with a theme plugin and the markdown / navigation / search extensions you need.</Description>
    <RootNamespace>NuStreamDocs</RootNamespace>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs.Common\NuStreamDocs.Common.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Markdown.Common\NuStreamDocs.Markdown.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core stays free of SourceDocParser. The CSharpApiGenerator plugin
         (NuStreamDocs.CSharpApiGenerator, separate assembly) takes the
         dependency and registers itself via builder.UseCSharpApiGenerator(). -->
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" />
    <PackageReference Include="System.IO.Hashing" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Tests" />
    <InternalsVisibleTo Include="NuStreamDocs.Benchmarks" />
  </ItemGroup>

</Project>
