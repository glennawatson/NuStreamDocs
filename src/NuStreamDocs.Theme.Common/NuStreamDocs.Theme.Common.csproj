<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Theme.Common</PackageId>
    <Description>Shared theme-side helpers for NuStreamDocs. Owns the byte-level icon-shortcode rewriter plus the common embedded-asset loader, theme-model loader, and page-shell base used by the built-in Material and Material 3 themes.</Description>
    <RootNamespace>NuStreamDocs.Theme.Common</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Markdown.Common\NuStreamDocs.Markdown.Common.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Templating\NuStreamDocs.Templating.csproj" />
  </ItemGroup>

</Project>
