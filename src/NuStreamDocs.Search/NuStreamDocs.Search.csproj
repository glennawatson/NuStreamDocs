<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Search</PackageId>
    <Description>Add full-text search to your NuStreamDocs site. The search index is built at the same time as the site — readers get instant results in the browser without a separate server.</Description>
    <RootNamespace>NuStreamDocs.Search</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.Search.Tests" />
  </ItemGroup>

</Project>
