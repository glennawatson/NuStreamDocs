<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.Markdown.Common</PackageId>
    <Description>Shared byte-level scanning helpers for NuStreamDocs markdown rewriters — fenced-code passthrough, inline-code passthrough, line-start / line-end probes, and indented-body detection. Pulled out of duplicated copies across Emoji / Keys / Abbr / Arithmatex / SmartSymbols / MagicLink / CaretTilde and the MarkdownExtensions internal helpers.</Description>
    <RootNamespace>NuStreamDocs.Markdown.Common</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs.Common\NuStreamDocs.Common.csproj" />
  </ItemGroup>

</Project>
