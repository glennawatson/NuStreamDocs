<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.SphinxInventory</PackageId>
    <Description>Publish an `objects.inv` inventory for your NuStreamDocs site so external documentation projects can cross-link into your pages by symbol name.</Description>
    <RootNamespace>NuStreamDocs.SphinxInventory</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Autorefs\NuStreamDocs.Autorefs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.SphinxInventory.Tests" />
  </ItemGroup>

</Project>
