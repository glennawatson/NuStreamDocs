<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.LinkValidator</PackageId>
    <Description>Catch broken links in your NuStreamDocs site at build time. Internal mode flags references to missing pages or anchors; optional external mode HTTP-checks absolute URLs.</Description>
    <RootNamespace>NuStreamDocs.LinkValidator</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <PackageReference Include="Polly" />
    <PackageReference Include="Polly.RateLimiting" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.LinkValidator.Tests" />
  </ItemGroup>

</Project>
