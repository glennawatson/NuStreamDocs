<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>NuStreamDocs.LinkValidator</PackageId>
    <Description>Strict-mode link validator for NuStreamDocs. Internal mode follows mkdocs --strict (relative links + anchors + nav/disk consistency); the optional external mode HTTP-checks absolute URLs through Polly with host-batched throttling and retry.</Description>
    <RootNamespace>NuStreamDocs.LinkValidator</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NuStreamDocs\NuStreamDocs.csproj" />
    <ProjectReference Include="..\NuStreamDocs.Common\NuStreamDocs.Common.csproj" />
    <PackageReference Include="Polly" />
    <PackageReference Include="Polly.RateLimiting" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NuStreamDocs.LinkValidator.Tests" />
  </ItemGroup>

</Project>
